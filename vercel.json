{
  "version": 2,
  "rewrites": [
    { "source": "/admin", "destination": "/api/admin-page" },
    { "source": "/admin/login", "destination": "/api/login-page" },
    { "source": "/identification", "destination": "/api/identification-page" },
    { "source": "/", "destination": "/api/index" }
  ],
  "headers": [
    {
      "source": "/(style.css|app.js|admin.js|login.js|identification.js)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
    }
  ]
}
