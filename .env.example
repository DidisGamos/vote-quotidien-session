# Copiez ce fichier en .env (ou configurez ces variables dans Vercel).

# Connexion à la base Supabase (au choix, une des deux) :
SUPABASE_CONNECTION_STRING=
# ou
DATABASE_URL=

# Alternative : client Supabase JS au lieu d'une connexion Postgres directe
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Mot de passe de l'espace admin (obligatoire pour activer la connexion)
ADMIN_PASSWORD=

# Optionnel : secret dédié pour signer les sessions admin.
# Si absent, ADMIN_PASSWORD est réutilisé comme secret de signature.
ADMIN_SESSION_SECRET=
